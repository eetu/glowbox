{
	"name": "@glowbox/nixie",
	"version": "1.0.0",
	"description": "Nixie-tube display component — a glowing vector-numeral rendering core in the glowbox family.",
	"keywords": [
		"nixie",
		"tube",
		"retro",
		"display",
		"clock",
		"glow"
	],
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"types": "./dist/index.d.ts",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/eetu/glowbox.git",
		"directory": "packages/nixie"
	},
	"homepage": "https://eetu.github.io/glowbox/",
	"scripts": {
		"build": "vite build",
		"prepack": "vite build",
		"test": "vitest run",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc --noEmit",
		"size": "size-limit"
	},
	"size-limit": [
		{
			"name": "esm (own code; core external)",
			"path": "dist/index.js",
			"ignore": [
				"@glowbox/led-grid"
			],
			"limit": "3.5 kB"
		}
	],
	"dependencies": {
		"@glowbox/led-grid": "workspace:^"
	},
	"devDependencies": {
		"@anarkisti/eslint-config": "^1",
		"@vitest/browser": "^4.1",
		"@vitest/browser-playwright": "^4.1",
		"eslint": "^10",
		"playwright": "^1.61",
		"typescript": "^6",
		"vite": "^8.1",
		"vite-plugin-dts": "^5",
		"vitest": "^4.1"
	}
}
