{
	"name": "@glowbox/react",
	"version": "1.0.1",
	"description": "glowbox components for React — <LedGrid> (3D WebGL LED grid) + <NixieTube> (nixie-tube display).",
	"keywords": [
		"react",
		"led",
		"led-cube",
		"webgl",
		"voxel",
		"3d",
		"nixie",
		"component"
	],
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"types": "./dist/index.d.ts",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/eetu/glowbox.git",
		"directory": "packages/react"
	},
	"homepage": "https://eetu.github.io/glowbox/",
	"scripts": {
		"build": "vite build",
		"prepack": "vite build",
		"test": "vitest run",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc --noEmit",
		"size": "size-limit"
	},
	"size-limit": [
		{
			"name": "esm (own code; react + core external)",
			"path": "dist/index.js",
			"ignore": [
				"react",
				"react-dom",
				"react/jsx-runtime",
				"@glowbox/led-grid",
				"@glowbox/nixie"
			],
			"limit": "1.5 kB"
		}
	],
	"peerDependencies": {
		"react": "^18 || ^19"
	},
	"dependencies": {
		"@glowbox/led-grid": "workspace:^",
		"@glowbox/nixie": "workspace:^"
	},
	"devDependencies": {
		"@anarkisti/eslint-config": "^1",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^5",
		"@vitest/browser": "^4.1",
		"@vitest/browser-playwright": "^4.1",
		"eslint": "^10",
		"playwright": "^1.61",
		"react": "^19",
		"react-dom": "^19",
		"typescript": "^6",
		"vite": "^8.1",
		"vite-plugin-dts": "^5",
		"vitest": "^4.1",
		"vitest-browser-react": "^1"
	}
}
