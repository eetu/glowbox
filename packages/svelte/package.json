{
	"name": "@glowbox/svelte",
	"version": "1.0.1",
	"description": "glowbox components for Svelte 5 — <LedGrid> (3D WebGL LED grid) + <NixieTube> (nixie-tube display).",
	"keywords": [
		"svelte",
		"led",
		"led-cube",
		"webgl",
		"voxel",
		"3d",
		"nixie",
		"component"
	],
	"license": "MIT",
	"type": "module",
	"files": [
		"dist"
	],
	"sideEffects": false,
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/eetu/glowbox.git",
		"directory": "packages/svelte"
	},
	"homepage": "https://eetu.github.io/glowbox/",
	"scripts": {
		"build": "svelte-package",
		"prepack": "svelte-package",
		"test": "vitest run",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "svelte-check --tsconfig ./tsconfig.json",
		"size": "size-limit"
	},
	"size-limit": [
		{
			"name": "shipped files (no bundle — components ship as .svelte source)",
			"path": "dist/**/*.{js,svelte}",
			"limit": "4 kB"
		}
	],
	"peerDependencies": {
		"svelte": "^5"
	},
	"dependencies": {
		"@glowbox/led-grid": "workspace:^",
		"@glowbox/nixie": "workspace:^"
	},
	"devDependencies": {
		"@anarkisti/eslint-config": "^1",
		"@size-limit/file": "^11",
		"@sveltejs/package": "^2.5",
		"@sveltejs/vite-plugin-svelte": "^7",
		"@vitest/browser": "^4.1",
		"@vitest/browser-playwright": "^4.1",
		"eslint": "^10",
		"playwright": "^1.61",
		"svelte": "^5.56",
		"svelte-check": "^4.7",
		"typescript": "^6",
		"vite": "^8.1",
		"vitest": "^4.1",
		"vitest-browser-svelte": "^2.2"
	}
}
